# French Learning Platform Environment Variables
# Copy this file to .env and set your own values

# Server Configuration
PORT=3001

# Security Configuration
JWT_SECRET=your-super-secure-jwt-secret-key-here-minimum-64-characters-long
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD_HASH=your-hashed-password-here

# Database Configuration (for future use)
# DATABASE_URL=your-database-connection-string
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=french_learning
# DB_USER=your-db-user
# DB_PASSWORD=your-db-password

# Email Configuration (for future use)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-email-password

# Other Configuration
NODE_ENV=development
